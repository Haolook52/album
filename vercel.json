{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "command": "npm install && npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/[^.]+$",
      "dest": "/index.html",
      "status": 200
    },
    {
      "src": "/(.*\\..+)$",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_VERSION": "18"
  },
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "cleanUrls": false,
  "trailingSlash": false
}
